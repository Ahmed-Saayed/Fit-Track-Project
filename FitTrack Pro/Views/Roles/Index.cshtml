@model IEnumerable<FitTrack_Pro.ViewModels.AddRoleViewModel>?

@{
 ViewData["Title"] = "Roles";
}

<div class="container-fluid px-0">
 <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
 <div>
 <h2 class="fw-bold mb-1">Roles</h2>
 <p class="text-muted mb-0">Manage application roles and permissions.</p>
 </div>
 <div>
 <a asp-action="Create" class="btn btn-primary rounded-pill px-4"><i class="fas fa-plus me-2"></i>Add Role</a>
 </div>
 </div>

 <div class="row g-4">
 @if (Model != null && Model.Any())
 {
 foreach (var role in Model)
 {
 <div class="col-md-4">
 <div class="card border-0 shadow-sm rounded-4 h-100">
 <div class="card-body d-flex flex-column">
 <div class="d-flex justify-content-between align-items-start mb-2">
 <h5 class="fw-bold mb-1">@role.RoleName</h5>
 <span class="badge bg-light text-muted">Role</span>
 </div>

 <p class="text-muted mb-3 small">Role used to control access and permissions for users assigned to this role.</p>

 <div class="mt-auto d-flex justify-content-end">
 <a asp-action="Edit" asp-route-id="@role.RoleName" class="btn btn-outline-secondary rounded-pill me-2">Edit</a>
 <form asp-action="Delete" asp-route-id="@role.RoleName" method="post" class="d-inline">
 @Html.AntiForgeryToken()
 <button type="submit" class="btn btn-danger rounded-pill">Delete</button>
 </form>
 </div>
 </div>
 </div>
 </div>
 }
 }
 <!-- If Model is null or empty, render nothing. The view only displays data provided by the controller. -->
 </div>
</div>

<style>
 .rounded-4 { border-radius:1rem !important; }
</style>
