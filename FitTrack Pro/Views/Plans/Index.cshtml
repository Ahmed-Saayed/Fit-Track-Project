@model IEnumerable<FitTrack_Pro.ViewModels.PlanResponseViewModel>

@{
    ViewData["Title"] = "Subscription Plans";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Syne:wght@500;600;700&display=swap" rel="stylesheet">

<style>
    .plan-wrap {
        font-family: 'DM Sans', sans-serif;
    }
    
    .syne-font {
        font-family: 'Syne', sans-serif;
    }

    .plan-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid transparent;
    }

        .plan-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
            border-color: #e5e7eb;
        }

    .btn-primary {
        background-color: #1a56db;
        border-color: #1a56db;
    }

        .btn-primary:hover {
            filter: brightness(1.08);
            background-color: #1a56db;
            border-color: #1a56db;
        }
    
    .btn-outline-primary {
        color: #1a56db;
        border-color: #1a56db;
    }
    
        .btn-outline-primary:hover {
            background-color: #1a56db;
            color: #fff;
        }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<div class="container-fluid px-0 py-3 plan-wrap">
    
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4 mt-2">
        <div>
            <h2 class="fw-bold mb-1 text-dark syne-font">Subscription Plans</h2>
            <p class="text-muted mb-0" style="font-size: 14px;">Manage available subscription plans and pricing for members.</p>
        </div>
        <div>
            <a asp-controller="Plans" asp-action="AddPlan" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-bold">
                <i class="fas fa-plus me-2"></i> Create New Plan
            </a>
        </div>
    </div>

    <div class="row g-4" id="plansList">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4" data-plan-id="@item.Id">
                    <div class="card border-0 shadow-sm rounded-4 h-100 plan-card bg-white">
                        <div class="card-body p-4 d-flex flex-column">
                            
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="fw-bold mb-0 text-dark syne-font pe-2">@item.Name</h5>
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-bold" style="font-size: 0.75rem;">
                                    <i class="far fa-calendar-alt me-1"></i> @item.DurationInDays Days
                                </span>
                            </div>

                            <div class="mb-3">
                                <h3 class="fw-bold text-primary syne-font mb-0">
                                    @item.Price.ToString("N0") <small class="fs-6 text-muted fw-medium">EGP</small>
                                </h3>
                            </div>

                            <p class="text-muted small mb-0 flex-grow-1 line-clamp-2">
                                @(string.IsNullOrWhiteSpace(item.Description) ? "No additional details provided for this plan." : item.Description)
                            </p>

                            <hr class="text-muted opacity-25 my-4" />

                            <div class="d-flex gap-2">
                                <a asp-controller="Plans" asp-action="Update" asp-route-id="@item.Id"
                                       class="btn btn-outline-primary rounded-pill flex-grow-1 fw-bold btn-sm py-2">
                                    <i class="fas fa-pen me-1"></i> Edit
                                </a>

                                <form asp-controller="Plans" asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline flex-grow-1 m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="button" class="btn btn-outline-danger rounded-pill w-100 fw-bold btn-sm py-2 btn-delete"
                                            data-id="@item.Id" data-name="@item.Name">
                                        <i class="fas fa-trash-alt me-1"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
                    <div class="card-body py-5">
                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4" style="width: 80px; height: 80px;">
                            <i class="fas fa-tags fs-1 text-muted opacity-50"></i>
                        </div>
                        <h4 class="fw-bold text-dark syne-font mb-2">No Plans Available</h4>
                        <p class="text-muted mb-4 mx-auto" style="max-width: 400px; font-size: 14px;">You haven't created any subscription plans yet. Set up your pricing packages to start enrolling members.</p>
                        <a asp-controller="Plans" asp-action="AddPlan" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm">
                            <i class="fas fa-plus me-2"></i> Create Your First Plan
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 plan-wrap">
            <div class="modal-header border-0 pb-0 mt-2 px-4">
                <h5 class="modal-title fw-bold text-danger syne-font"><i class="fas fa-exclamation-triangle me-2"></i> Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 py-3 text-muted" style="font-size: 14px;">
                <p class="mb-0" id="confirmDeleteMessage">Are you sure you want to delete this plan?</p>
                <small class="d-block mt-2">This action cannot be undone and might affect members currently using it.</small>
            </div>
            <div class="modal-footer border-0 px-4 pb-4">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-medium" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmDeleteBtn" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">Yes, Delete Plan</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="resultModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4 plan-wrap text-center p-3">
            <div class="modal-body py-4">
                <div id="resultIcon" class="mb-3">
                    <i class="fas fa-info-circle fs-1 text-primary"></i>
                </div>
                <h5 class="fw-bold text-dark syne-font mb-2" id="resultModalLabel">System Message</h5>
                <p class="mb-0 text-muted" id="resultMessage" style="font-size: 14px;"></p>
            </div>
            <div class="modal-footer border-0 justify-content-center pb-3 pt-0">
                <button type="button" class="btn btn-primary rounded-pill px-5 fw-bold" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var deleteButtons = document.querySelectorAll('.btn-delete');
            var confirmModal = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));
            var resultModal = new bootstrap.Modal(document.getElementById('resultModal'));
            
            var confirmMessage = document.getElementById('confirmDeleteMessage');
            var resultMessage = document.getElementById('resultMessage');
            var resultIcon = document.getElementById('resultIcon');
            var confirmDeleteBtn = document.getElementById('confirmDeleteBtn');

            var selectedForm = null;
            var selectedCard = null;

            deleteButtons.forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    selectedForm = btn.closest('form');
                    selectedCard = btn.closest('[data-plan-id]');
                    var planName = btn.getAttribute('data-name') || 'this plan';
                    confirmMessage.innerHTML = `Are you sure you want to delete <strong class="text-dark">"${planName}"</strong>?`;
                    confirmModal.show();
                });
            });

            confirmDeleteBtn.addEventListener('click', function () {
                if (!selectedForm) return;

                var action = selectedForm.getAttribute('action');
                var formData = new FormData(selectedForm);

                // Disable button to prevent double-clicks
                confirmDeleteBtn.disabled = true;
                confirmDeleteBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Deleting...';

                // Perform AJAX POST
                fetch(action, {
                    method: 'POST',
                    body: formData,
                    credentials: 'same-origin'
                })
                .then(function (response) {
                    confirmModal.hide();
                    confirmDeleteBtn.disabled = false;
                    confirmDeleteBtn.innerHTML = 'Yes, Delete Plan';

                    if (response.ok) {
                        // Success
                        resultIcon.innerHTML = '<i class="fas fa-check-circle fs-1 text-success"></i>';
                        resultMessage.textContent = 'Plan has been deleted successfully.';
                        
                        // Add fade-out animation before removing
                        if (selectedCard) {
                            selectedCard.style.transition = "opacity 0.3s ease, transform 0.3s ease";
                            selectedCard.style.opacity = "0";
                            selectedCard.style.transform = "scale(0.9)";
                            setTimeout(() => {
                                if(selectedCard.parentNode) selectedCard.parentNode.removeChild(selectedCard);
                                
                                // Check if grid is empty, if so, reload to show empty state
                                if(document.getElementById('plansList').children.length === 0) {
                                    window.location.reload();
                                }
                            }, 300);
                        }
                    } else {
                        // Error
                        resultIcon.innerHTML = '<i class="fas fa-times-circle fs-1 text-danger"></i>';
                        resultMessage.textContent = 'An error occurred while deleting the plan. It might be assigned to active members.';
                    }
                    resultModal.show();
                })
                .catch(function (err) {
                    confirmModal.hide();
                    confirmDeleteBtn.disabled = false;
                    confirmDeleteBtn.innerHTML = 'Yes, Delete Plan';
                    
                    resultIcon.innerHTML = '<i class="fas fa-times-circle fs-1 text-danger"></i>';
                    resultMessage.textContent = 'A network error occurred. Please try again later.';
                    resultModal.show();
                });
            });
        });
    </script>
}