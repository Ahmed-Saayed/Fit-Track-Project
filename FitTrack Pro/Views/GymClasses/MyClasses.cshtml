@model IEnumerable<FitTrack_Pro.ViewModels.GymClassRowViewModel>

@{
    ViewData["Title"] = "My Assigned Classes";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">My Assigned Classes</h2>
            <p class="text-muted">Manage and view your upcoming gym sessions.</p>
        </div>
        <span class="badge bg-primary rounded-pill px-4 py-2 fs-6">
            <i class="bi bi-calendar-event me-2"></i> @Model.Count() Total Classes
        </span>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 20px;">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-calendar-x display-1 text-muted opacity-25"></i>
                    </div>
                    <h4 class="text-muted">No classes assigned yet</h4>
                    <p class="text-muted">When you're assigned to a class, it will appear here.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 custom-table">
                        <thead class="bg-light">
                            <tr>
                                <th class="px-4 py-3 border-0">Class Name</th>
                                <th class="px-4 py-3 border-0">Schedule</th>
                                <th class="px-4 py-3 border-0 text-center">Duration</th>
                                <th class="px-4 py-3 border-0 text-center">Capacity</th>
                                <th class="px-4 py-3 border-0 text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderBy(c => c.ScheduleTime))
                            {
                                <tr>
                                    <td class="px-4 py-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3">
                                                <i class="bi bi-activity"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@item.Name</div>
                                                <div class="small text-muted">Created: @item.CreatedAt.ToString("MMM dd, yyyy")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4">
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold text-dark">
                                                <i class="bi bi-clock-history me-1 text-primary"></i>
                                                @item.ScheduleTime.ToString("HH:mm")
                                            </span>
                                            <span class="small text-muted">@item.ScheduleTime.ToString("dddd, MMM dd")</span>
                                        </div>
                                    </td>
                                    <td class="px-4 text-center">
                                        <span class="badge bg-info bg-opacity-10 text-info border-0 fw-normal px-3 py-2 rounded-pill">
                                            @item.DurationInMinutes mins
                                        </span>
                                    </td>
                                    <td class="px-4 text-center">
                                        <div class="d-inline-flex align-items-center">
                                            <span class="fw-bold text-dark me-2">@item.AttendeeCount / @item.MaxCapacity</span>
                                            <div class="progress" style="width: 50px; height: 6px;">
                                                @{
                                                    var percent = (item.AttendeeCount * 100) / (item.MaxCapacity > 0 ? item.MaxCapacity : 1);
                                                    var color = percent > 80 ? "bg-danger" : (percent > 50 ? "bg-warning" : "bg-success");
                                                }
                                                <div class="progress-bar @color" role="progressbar" style="width: @percent%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4 text-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            View Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .custom-table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #64748b;
    }
    .custom-table tbody tr {
        transition: all 0.2s ease;
    }
    .custom-table tbody tr:hover {
        background-color: #f8fafc;
    }
</style>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
