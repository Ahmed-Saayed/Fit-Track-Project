@model FitTrack_Pro.ViewModels.GymClassDetailsViewModel
@{
    ViewData["Title"] = Model.Name;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=Syne:wght@500;600&display=swap" rel="stylesheet">

<style>
    .d-wrap { font-family:'DM Sans',sans-serif; }
    .d-breadcrumb { display:flex; align-items:center; gap:6px; font-size:13px; color:#6b7280; margin-bottom:1.75rem; }
    .d-breadcrumb a { color:#1a56db; text-decoration:none; }
    .d-breadcrumb a:hover { text-decoration:underline; }
    .d-page-header { display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:1.75rem; }
    .d-page-header h1 { font-family:'Syne',sans-serif; font-size:22px; font-weight:600; letter-spacing:-.3px; margin:0; }
    .d-page-header p { font-size:13px; color:#6b7280; margin:3px 0 0; }
    .d-actions { display:flex; gap:8px; flex-wrap:wrap; }
    .d-btn { padding:8px 16px; border-radius:8px; font-family:'DM Sans',sans-serif; font-size:13px; font-weight:500; cursor:pointer; transition:all .15s; border:0.5px solid transparent; display:inline-flex; align-items:center; gap:6px; text-decoration:none; white-space:nowrap; }
    .d-btn svg { width:13px; height:13px; flex-shrink:0; }
    .d-btn-primary { background:#1a56db; border-color:#1a56db; color:#fff; }
    .d-btn-primary:hover { filter:brightness(1.08); color:#fff; }
    .d-btn-ghost { background:transparent; border-color:#d1d5db; color:#6b7280; }
    .d-btn-ghost:hover { background:#f3f4f6; color:#111827; }
    .d-card { background:#fff; border:0.5px solid #e5e7eb; border-radius:12px; overflow:hidden; margin-bottom:16px; }
    .d-card-header { padding:12px 20px; border-bottom:0.5px solid #e5e7eb; background:#f9fafb; display:flex; align-items:center; gap:8px; }
    .d-card-header svg { width:15px; height:15px; stroke:#1a56db; flex-shrink:0; }
    .d-card-title { font-family:'Syne',sans-serif; font-size:14px; font-weight:500; margin:0; }
    .d-card-body { padding:20px; }
    .d-info-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:10px; }
    .d-info-tile { background:#f9fafb; border:0.5px solid #e5e7eb; border-radius:8px; padding:12px 14px; }
    .d-info-tile-label { font-size:11px; font-weight:500; color:#9ca3af; letter-spacing:.4px; text-transform:uppercase; margin:0 0 5px; }
    .d-info-tile-val { font-family:'Syne',sans-serif; font-size:16px; font-weight:600; color:#111827; margin:0; }
    .d-badge { display:inline-flex; align-items:center; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:500; }
    .d-badge-class { background:#e8effe; color:#185FA5; border:0.5px solid #B5D4F4; }
    .d-badge-full  { background:#fcebeb; color:#A32D2D; border:0.5px solid #F7C1C1; }
</style>

<div class="d-wrap">

    <div class="d-breadcrumb">
        <a asp-action="Index">Gym Classes</a>
        <span>›</span>
        <span>@Model.Name</span>
    </div>

    <div class="d-page-header">
        <div>
            <h1>@Model.Name</h1>
            <p>Gym class — ID #@Model.Id</p>
        </div>
        <div class="d-actions">
            <a asp-action="Index" class="d-btn d-btn-ghost">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 3L5 8l5 5" /></svg>
                Back
            </a>
            <a asp-action="AssignMember" asp-route-id="@Model.Id" class="d-btn d-btn-primary" style="background:#059669;border-color:#059669">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 3v10M3 8h10" /></svg>
                Assign member
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="d-btn d-btn-primary">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 2l4 4-7 7H3v-4l7-7z" /></svg>
                Edit class
            </a>
        </div>
    </div>

    <div class="d-card">
        <div class="d-card-header">
            <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5">
                <rect x="1" y="4" width="14" height="9" rx="2" />
                <path d="M4 4V3a1 1 0 011-1h6a1 1 0 011 1v1M1 8h14" />
            </svg>
            <span class="d-card-title">Class overview</span>
        </div>
        <div class="d-card-body">
            <div class="d-info-grid">
                <div class="d-info-tile">
                    <p class="d-info-tile-label">Trainer</p>
                    <p class="d-info-tile-val" style="font-size:14px">@Model.TrainerName</p>
                </div>
                <div class="d-info-tile">
                    <p class="d-info-tile-label">Schedule</p>
                    <p class="d-info-tile-val" style="font-size:14px">@Model.ScheduleTime.ToString("dd MMM yyyy")<br /><span style="font-size:13px;color:#6b7280">@Model.ScheduleTime.ToString("HH:mm")</span></p>
                </div>
                <div class="d-info-tile">
                    <p class="d-info-tile-label">Duration</p>
                    <p class="d-info-tile-val">@Model.DurationInMinutes <span style="font-size:13px;font-weight:400;color:#6b7280">min</span></p>
                </div>
                <div class="d-info-tile">
                    <p class="d-info-tile-label">Capacity</p>
                    @{
                        var isFull = Model.AttendeeCount >= Model.MaxCapacity;
                    }
                    <p class="d-info-tile-val">
                        <span class="d-badge @(isFull ? "d-badge-full" : "d-badge-class")">
                            @Model.AttendeeCount / @Model.MaxCapacity
                        </span>
                    </p>
                </div>
                <div class="d-info-tile">
                    <p class="d-info-tile-label">Created</p>
                    <p class="d-info-tile-val" style="font-size:14px">@Model.CreatedAt.ToString("dd MMM yyyy")</p>
                </div>
            </div>
        </div>
    </div>

    <div class="d-card">
        <div class="d-card-header">
            <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5">
                <circle cx="5" cy="5" r="2" /><circle cx="11" cy="5" r="2" />
                <path d="M1 13c0-2 1.5-4 4-4h6c2.5 0 4 2 4 4" />
            </svg>
            <span class="d-card-title">Attendees (@Model.AttendeeCount)</span>
        </div>
        <div class="d-card-body" style="padding:0">
            @if (Model.Attendees.Any())
            {
                <table class="table table-hover mb-0" style="font-size:13px">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Member</th>
                            <th>Phone</th>
                            <th>Attendance Date</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var attendee in Model.Attendees)
                        {
                            <tr>
                                <td class="ps-4">
                                    <a asp-controller="Members" asp-action="Details" asp-route-id="@attendee.MemberId" 
                                       style="font-weight:500;color:#111827;text-decoration:none">
                                        @attendee.MemberName
                                    </a>
                                </td>
                                <td class="text-muted">@attendee.MemberPhoneNumber</td>
                                <td>@attendee.AttendanceDate.ToString("dd MMM yyyy, HH:mm")</td>
                                <td class="text-end pe-4">
                                    <a asp-controller="Members" asp-action="Details" asp-route-id="@attendee.MemberId" 
                                       class="btn btn-sm btn-link text-primary p-0">View profile</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:40px 20px;text-align:center;color:#6b7280;font-size:13px">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" 
                         style="width:32px;height:32px;margin-bottom:8px;opacity:.5">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                    </svg>
                    <p>No members assigned to this class yet.</p>
                </div>
            }
        </div>
    </div>

</div>
