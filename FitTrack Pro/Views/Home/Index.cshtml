@model FitTrack_Pro.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Overview";
}

<div class="container-fluid px-0">
    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
        <div>
            <h2 class="fw-bold mb-1">Dashboard Overview</h2>
            <p class="text-muted mb-0">Real-time performance tracking for today, @DateTime.Now.ToString("MMM dd").</p>
        </div>
        @* <div>
            <button class="btn btn-outline-secondary rounded-pill me-2 px-4"><i class="fas fa-download me-2"></i>Daily Report</button>
            <button class="btn btn-primary rounded-pill px-4"><i class="fas fa-plus me-2"></i>New Session</button>
        </div> *@
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="border-left: 5px solid #0D6EFD !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="text-muted fw-bold mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">TOTAL ACTIVE MEMBERS</p>
                    </div>
                    <h2 class="fw-bold mb-0">@Model.TotalActiveMembers.ToString("N0")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="border-left: 5px solid #198754 !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="text-muted fw-bold mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">TODAY'S REVENUE</p>
                    </div>
                    <h2 class="fw-bold mb-0">$@Model.TodaysRevenue.ToString("N0")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="border-left: 5px solid #DC3545 !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="text-muted fw-bold mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">EXPIRING SOON</p>
                        <span class="text-danger fw-bold" style="font-size: 0.85rem;">@Model.ExpiringSubscriptions !</span>
                    </div>
                    <h2 class="fw-bold mb-0">@Model.ExpiringSubscriptions</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="border-left: 5px solid #6C757D !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="text-muted fw-bold mb-1" style="font-size: 0.8rem; letter-spacing: 1px;">CLASSES TODAY</p>
                    </div>
                    <h2 class="fw-bold mb-0">@Model.ClassesToday</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4 bg-light">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Quick Actions</h6>
                    <a asp-controller="Members" asp-action="Create" class="text-decoration-none">
                        <div class="card border-0 shadow-sm rounded-3 mb-3 hover-effect">
                            <div class="card-body d-flex align-items-center">
                                <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3 me-3">
                                    <i class="fas fa-user-plus fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="text-dark fw-bold mb-0">Register New Member</h6>
                                    <small class="text-muted">Create profile & plan</small>
                                </div>
                            </div>
                        </div>
                    </a>

                    @* <a href="#" class="text-decoration-none">
                        <div class="card border-0 shadow-sm rounded-3 mb-3 hover-effect">
                            <div class="card-body d-flex align-items-center">
                                <div class="bg-success bg-opacity-10 text-success p-3 rounded-3 me-3">
                                    <i class="fas fa-qrcode fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="text-dark fw-bold mb-0">Record Visit</h6>
                                    <small class="text-muted">Quick check-in</small>
                                </div>
                            </div>
                        </div>
                    </a> *@
                </div>
            </div>

            @* <div class="card border-0 shadow-sm rounded-4 text-center pb-3">
                <div class="card-body p-4">
                    <p class="text-muted fw-bold mb-4" style="font-size: 0.8rem; letter-spacing: 1px;">EST. GYM CAPACITY</p>
                    <div class="display-4 fw-bold text-primary mb-2">@Model.GymCapacityPercentage%</div>
                    <small class="text-muted">Based on class fill rates</small>
                </div>
            </div> *@
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h6 class="fw-bold mb-0">Recent Activity</h6>
                        <a href="#" class="text-decoration-none fw-bold small text-primary">VIEW ALL LOGS</a>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-borderless align-middle">
                            <thead class="text-muted small fw-bold" style="letter-spacing: 1px;">
                                <tr>
                                    <th scope="col" style="width: 15%;">TIME</th>
                                    <th scope="col" style="width: 50%;">MEMBER NAME</th>
                                    <th scope="col" style="width: 35%;">STATUS</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentActivities.Any())
                                {
                                    @foreach (var activity in Model.RecentActivities)
                                    {
                                        <tr style="border-bottom: 1px solid #f8f9fa;">
                                            <td class="text-muted small fw-bold">@activity.Time</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="rounded-circle bg-light d-flex justify-content-center align-items-center text-secondary fw-bold me-3" style="width: 35px; height: 35px; font-size: 0.8rem;">
                                                        @activity.MemberInitials
                                                    </div>
                                                    <span class="fw-bold text-dark">@activity.MemberName</span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-@activity.StatusColor bg-opacity-10 text-@activity.StatusColor px-3 py-2 rounded-pill border border-@activity.StatusColor border-opacity-25">
                                                    <i class="fas fa-circle me-1" style="font-size: 0.4rem; vertical-align: middle;"></i> @activity.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-4">No recent activity found today.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="row mt-4 g-3">
                        <div class="col-md-6">
                            <div class="card bg-light border-0 rounded-4 h-100">
                                <div class="card-body">
                                    <p class="text-muted fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 1px;">MEMBER GROWTH</p>
                                    <h4 class="fw-bold mb-0">@Model.MemberGrowth</h4>
                                    <small class="text-muted" style="font-size: 0.7rem;">New members this month</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light border-0 rounded-4 h-100">
                                <div class="card-body">
                                    <p class="text-muted fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 1px;">CLASS FILL RATE</p>
                                    <h4 class="fw-bold mb-0">@Model.ClassFillRate%</h4>
                                    <small class="text-muted" style="font-size: 0.7rem;">Average occupancy today</small>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-effect {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-effect:hover {
            transform: translateY(-2px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.08) !important;
            cursor: pointer;
        }
</style>