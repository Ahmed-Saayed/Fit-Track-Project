@using System.Collections.Generic
@using FitTrack_Pro.ViewModels
@using System.Security.Claims
@model IEnumerable<ChatsViewModel>

@{
    ViewData["Title"] = "Chats";
    string currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
}

<style>
/* Container */
.chat-list { max-width:980px; margin:28px auto; font-family: "Segoe UI", Roboto, Arial, sans-serif; color:#0f172a; }

/* Header */
.chat-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
.chat-header h2 { margin:0; font-size:1.25rem; }

/* Chat item */
.chat-item {
  display:flex;
  align-items:center;
  padding:12px 14px;
  border-radius:12px;
  transition: background .12s ease, transform .06s ease;
  text-decoration:none;
  color:inherit;
  border:1px solid rgba(15,23,42,0.04);
  background:#fff;
  margin-bottom:10px;
}
.chat-item:hover {
  background: #fbfdff;
  transform: translateY(-3px);
  box-shadow: 0 6px 18px rgba(15,23,42,0.06);
}

/* Avatar - true circle */
.avatar {
  width:64px;
  height:64px;
  border-radius:50%;
  flex: 0 0 64px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  font-weight:700;
  color:#ffffff;
  font-size:1.05rem;
  margin-right:14px;
  user-select:none;
  box-shadow: 0 4px 12px rgba(2,6,23,0.08);
  background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%);
  overflow:hidden;
  border: 2px solid rgba(255,255,255,0.06);
}

/* If you later provide an image, it will fill the circle */
.avatar img { width:100%; height:100%; object-fit:cover; display:block; }

/* Main content */
.chat-main { flex:1; min-width:0; }
.chat-name { margin:0; font-size:1rem; font-weight:600; color:#0f172a; }
.chat-sub { margin-top:6px; color:#6b7280; font-size:.92rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

/* Metadata on the right */
.chat-meta { text-align:right; margin-left:12px; min-width:120px; }
.chat-time { color:#9ca3af; font-size:.82rem; }

/* Empty state */
.no-chats { text-align:center; color:#6b7280; padding:28px 0; }

/* Responsive adjustments */
@@media (max-width:720px) {
  .chat-meta { display:none; }
  .avatar { width:52px; height:52px; flex:0 0 52px; font-size:.95rem; margin-right:12px; }
  .chat-item { padding:10px 12px; }
}
</style>

<div class="chat-list">
  <div class="chat-header">
    <h2>Chats</h2>
  </div>

  @if (!Model?.Any() ?? true)
  {
    <div class="no-chats">No chats to display.</div>
  }
  else
  {
    foreach (var vm in Model)
    {
      // Build initials from first two name parts
      var parts = (vm.FullName ?? string.Empty).Split(' ', System.StringSplitOptions.RemoveEmptyEntries);
      string initials = string.Empty;
      if (parts.Length > 0) initials += char.ToUpperInvariant(parts[0][0]);
      if (parts.Length > 1) initials += char.ToUpperInvariant(parts[1][0]);

      string messageLine = string.Empty;
      if (!string.IsNullOrEmpty(vm.lastMessage))
      {
        if (!string.IsNullOrEmpty(vm.lastMessageSenderId) && vm.lastMessageSenderId == currentUserId)
        {
          messageLine = "You: " + vm.lastMessage;
        }
        else
        {
          messageLine = (vm.FullName ?? string.Empty) + ": " + vm.lastMessage;
        }
      }

      string time = vm.lastMessageCreationDate?.ToLocalTime().ToString("g") ?? string.Empty;
  <a class="chat-item" href="@Url.Action("GetChatMessages", "Chat", new { UserId = vm.UserId ,FullName=vm.FullName})" aria-label="Open chat with @vm.FullName">
    <div class="avatar" aria-hidden="true">@initials</div>

    <div class="chat-main">
      <p class="chat-name">@vm.FullName</p>

      @if (!string.IsNullOrEmpty(messageLine))
      {
        <div class="chat-sub">@messageLine</div>
      }
      else
      {
        <div class="chat-sub">No messages yet</div>
      }
    </div>

    <div class="chat-meta">
      @if (!string.IsNullOrEmpty(time))
      {
        <div class="chat-time">@time</div>
      }
    </div>
  </a>
    }
  }
</div>
