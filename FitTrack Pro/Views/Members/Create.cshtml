@model FitTrack_Pro.ViewModels.MemberFormViewModel
@{
    var isEdit = Model.Id != 0;
    ViewData["Title"] = isEdit ? "Edit Member" : "Add Member";

    var nameParts = Model.FullName?.Split(' ', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
    var initials = nameParts.Length >= 2
    ? $"{nameParts[0][0]}{nameParts[^1][0]}"
    : (nameParts.Length == 1 && nameParts[0].Length > 0 ? nameParts[0][..Math.Min(2, nameParts[0].Length)] : "?");
    initials = initials.ToUpper();
    
    var memberAge = Model.BirthDate != default
    ? (int)((DateTime.Today - Model.BirthDate).TotalDays / 365.25) : 0;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Syne:wght@500;600;700&display=swap" rel="stylesheet">

<style>
    .form-wrap {
        font-family: 'DM Sans', sans-serif;
    }
    h1, h2, h3, h4, h5, h6, .syne-font {
        font-family: 'Syne', sans-serif;
    }
    
    /* Modern Inputs */
    .modern-input {
        background-color: #f8f9fa;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 0.75rem 1rem 0.75rem 2.75rem; /* Space for icon */
        font-size: 0.95rem;
        color: #111827;
        transition: all 0.2s ease;
    }
    .modern-input:focus {
        background-color: #ffffff;
        border-color: #0D6EFD;
        box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
        outline: none;
    }
    .input-icon {
        position: absolute;
        top: 50%;
        left: 1rem;
        transform: translateY(-50%);
        color: #9ca3af;
        pointer-events: none;
        z-index: 10;
    }
    
    /* Gender Radio Buttons */
    .btn-check:checked + .btn-outline-primary {
        background-color: #e8effe;
        color: #0D6EFD;
        border-color: #0D6EFD;
        font-weight: 600;
    }
    .btn-outline-primary {
        border-color: #e5e7eb;
        color: #6b7280;
    }
    .btn-outline-primary:hover {
        background-color: #f8f9fa;
        border-color: #d1d5db;
        color: #111827;
    }

    /* Section Divider */
    .form-divider {
        display: flex;
        align-items: center;
        text-align: center;
        color: #9ca3af;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin: 2rem 0 1.5rem;
    }
    .form-divider::before, .form-divider::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid #e5e7eb;
    }
    .form-divider:not(:empty)::before { margin-right: 1rem; }
    .form-divider:not(:empty)::after { margin-left: 1rem; }
</style>

<div class="container-fluid px-0 py-3 form-wrap">

    <div class="mb-4">
        <div class="d-flex align-items-center gap-2 small text-muted mb-3">
            <a asp-action="Index" class="text-primary text-decoration-none fw-medium">Members</a>
            <i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i>
            @if (isEdit)
            {
                <a asp-action="Details" asp-route-id="@Model.Id" class="text-primary text-decoration-none fw-medium">@Model.FullName</a>
                <i class="fas fa-chevron-right" style="font-size: 0.7rem;"></i>
                <span class="text-dark">Edit Profile</span>
            }
            else
            {
                <span class="text-dark">Add New Member</span>
            }
        </div>

        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
            <div>
                <h2 class="fw-bold mb-1 text-dark syne-font">@(isEdit ? "Edit Member Profile" : "Register New Member")</h2>
                <p class="text-muted mb-0">@(isEdit ? "Update personal information and account settings." : "Fill in the details below to create a new profile.")</p>
            </div>
            @if (isEdit)
            {
                <div class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-medium border border-primary border-opacity-25">
                    <i class="fas fa-id-card me-2"></i> Member ID: #@Model.Id
                </div>
            }
        </div>
    </div>

    <div class="row g-4">

        <div class="col-lg-4 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 text-center sticky-top" style="top: 20px;">
                <div class="card-body p-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 border border-primary border-opacity-25 syne-font" 
                         style="width: 80px; height: 80px; font-size: 24px; font-weight: 700;" id="js-avatar">
                        @initials
                    </div>
                    <h5 class="fw-bold text-dark mb-1 syne-font" id="js-name">@(string.IsNullOrWhiteSpace(Model.FullName) ? "New Member" : Model.FullName)</h5>
                    <p class="text-muted small mb-2" id="js-phone">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "No phone number" : Model.PhoneNumber)</p>
                    
                    <div class="badge bg-light text-secondary border rounded-pill px-3 py-1 mb-4">
                        @(isEdit ? "Editing Mode" : "New Registration")
                    </div>

                    <div class="text-start border-top pt-3">
                        <div class="d-flex align-items-center justify-content-between mb-2 small">
                            <span class="text-muted fw-medium">Barcode:</span>
                            <span class="text-dark fw-bold font-monospace" id="js-barcode">@(string.IsNullOrWhiteSpace(Model.Barcode) ? "—" : Model.Barcode)</span>
                        </div>
                        <div class="d-flex align-items-center justify-content-between mb-2 small">
                            <span class="text-muted fw-medium">Gender:</span>
                            <span class="text-dark fw-bold" id="js-gender">@(string.IsNullOrWhiteSpace(Model.Gender) ? "—" : Model.Gender)</span>
                        </div>
                        @if (isEdit && memberAge > 0)
                        {
                            <div class="d-flex align-items-center justify-content-between small">
                                <span class="text-muted fw-medium">Age:</span>
                                <span class="text-dark fw-bold">@memberAge yrs</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8 col-xl-9">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 px-md-5">
                    <h5 class="fw-bold text-dark syne-font mb-0">
                        <i class="fas @(isEdit ? "fa-user-edit" : "fa-user-plus") text-primary me-2"></i> Personal Information
                    </h5>
                </div>
                
                <div class="card-body p-4 p-md-5 pt-3">
                    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" id="memberForm" novalidate>
                        @Html.AntiForgeryToken()
                        @if (isEdit) { <input asp-for="Id" type="hidden" /> }

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small rounded-3" role="alert"></div>

                        <div class="mb-4">
                            <label asp-for="FullName" class="form-label small text-muted fw-bold text-uppercase" style="letter-spacing:0.5px;">Full Name</label>
                            <div class="position-relative">
                                <i class="fas fa-user input-icon"></i>
                                <input asp-for="FullName" id="inp-name" class="form-control modern-input @(ViewData.ModelState["FullName"]?.Errors.Any() == true ? "is-invalid" : "")" placeholder="e.g. Marcus Webb" autocomplete="name" oninput="syncPreview()" />
                            </div>
                            <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label small text-muted fw-bold text-uppercase" style="letter-spacing:0.5px;">Phone Number</label>
                                <div class="position-relative">
                                    <i class="fas fa-phone-alt input-icon"></i>
                                    <input asp-for="PhoneNumber" id="inp-phone" class="form-control modern-input" placeholder="01X XXX XXXX" oninput="document.getElementById('js-phone').textContent=this.value||'No phone number'" />
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Barcode" class="form-label small text-muted fw-bold text-uppercase" style="letter-spacing:0.5px;">Barcode / ID</label>
                                <div class="position-relative">
                                    <i class="fas fa-barcode input-icon"></i>
                                    <input asp-for="Barcode" id="inp-barcode" class="form-control modern-input" placeholder="FT-0001" oninput="document.getElementById('js-barcode').textContent=this.value||'—'" />
                                </div>
                                <small class="text-muted d-block mt-1">Must be unique across all members.</small>
                                <span asp-validation-for="Barcode" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="row g-4 mb-2">
                            <div class="col-md-6">
                                <label asp-for="BirthDate" class="form-label small text-muted fw-bold text-uppercase" style="letter-spacing:0.5px;">Date of Birth</label>
                                <div class="position-relative">
                                    <input asp-for="BirthDate" type="date" class="form-control modern-input ps-3" />
                                </div>
                                <span asp-validation-for="BirthDate" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-muted fw-bold text-uppercase" style="letter-spacing:0.5px;">Gender</label>
                                <div class="d-flex gap-3">
                                    <input type="radio" class="btn-check" name="Gender" id="g-male" value="Male" autocomplete="off" onchange="document.getElementById('js-gender').textContent='Male'" @(Model.Gender == "Male" || !isEdit ? "checked" : "")>
                                    <label class="btn btn-outline-primary rounded-3 w-100 py-2" for="g-male">
                                        <i class="fas fa-mars me-2"></i> Male
                                    </label>

                                    <input type="radio" class="btn-check" name="Gender" id="g-female" value="Female" autocomplete="off" onchange="document.getElementById('js-gender').textContent='Female'" @(Model.Gender == "Female" ? "checked" : "")>
                                    <label class="btn btn-outline-primary rounded-3 w-100 py-2" for="g-female">
                                        <i class="fas fa-venus me-2"></i> Female
                                    </label>
                                </div>
                            </div>
                        </div>

                        @if (!isEdit)
                        {
                            <div class="form-divider">Account Credentials</div>

                            <div class="mb-4">
                                <label asp-for="UserName" class="form-label small text-muted fw-bold text-uppercase" style="letter-spacing:0.5px;">Email Address</label>
                                <div class="position-relative">
                                    <i class="fas fa-envelope input-icon"></i>
                                    <input asp-for="UserName" type="email" class="form-control modern-input" placeholder="name@example.com" />
                                </div>
                                <span asp-validation-for="UserName" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="row g-4 mb-2">
                                <div class="col-md-6">
                                    <label asp-for="Password" class="form-label small text-muted fw-bold text-uppercase" style="letter-spacing:0.5px;">Password</label>
                                    <div class="position-relative">
                                        <i class="fas fa-lock input-icon"></i>
                                        <input asp-for="Password" type="password" class="form-control modern-input" placeholder="Secure password" autocomplete="new-password" />
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="ConfirmPassword" class="form-label small text-muted fw-bold text-uppercase" style="letter-spacing:0.5px;">Confirm Password</label>
                                    <div class="position-relative">
                                        <i class="fas fa-check-circle input-icon"></i>
                                        <input asp-for="ConfirmPassword" type="password" class="form-control modern-input" placeholder="Repeat password" autocomplete="new-password" />
                                    </div>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        }

                        <div class="form-divider">Medical Details</div>
                        <div class="mb-4">
                            <label asp-for="MedicalNotes" class="form-label small text-muted fw-bold text-uppercase" style="letter-spacing:0.5px;">Medical Notes (Optional)</label>
                            <div class="position-relative">
                                <i class="fas fa-notes-medical input-icon" style="top: 1.25rem; transform: none;"></i>
                                <textarea asp-for="MedicalNotes" class="form-control modern-input" rows="3" placeholder="Any relevant health conditions, allergies, or past injuries..."></textarea>
                            </div>
                        </div>

                        @if (isEdit)
                        {
                            <div class="form-divider text-danger">Danger Zone</div>
                            <div class="bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded-4 p-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
                                <div>
                                    <h6 class="text-danger fw-bold mb-1">Remove Member</h6>
                                    <small class="text-danger opacity-75">Soft delete — the record is retained in the database but hidden.</small>
                                </div>
                                <button type="button" class="btn btn-outline-danger rounded-pill fw-bold bg-white" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
                                    <i class="fas fa-trash-alt me-2"></i> Remove Member
                                </button>
                            </div>
                        }

                    </form>
                </div>
                
                <div class="card-footer bg-light border-0 p-4 p-md-5 rounded-bottom-4 d-flex justify-content-end gap-3">
                    @if (isEdit)
                    {
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link text-muted text-decoration-none fw-medium">Discard</a>
                    }
                    else
                    {
                        <a asp-action="Index" class="btn btn-link text-muted text-decoration-none fw-medium">Cancel</a>
                    }
                    
                    <button type="submit" form="memberForm" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm">
                        <i class="fas @(isEdit ? "fa-save" : "fa-check") me-2"></i> @(isEdit ? "Save Changes" : "Register Member")
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (isEdit)
{
    <div class="modal fade" id="confirmDeleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4 form-wrap">
                <div class="modal-header border-0 pb-0 mt-2 px-4">
                    <h5 class="modal-title fw-bold text-danger syne-font"><i class="fas fa-exclamation-triangle me-2"></i> Confirm Removal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body px-4 py-3 text-muted">
                    Are you sure you want to remove <strong class="text-dark">@Model.FullName</strong>?
                    <br><small class="d-block mt-2">This will soft-delete the member, meaning they won't appear in lists but data is preserved.</small>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-medium" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="Delete" asp-controller="Members" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">
                            Remove Member
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function syncPreview() {
            const val = document.getElementById('inp-name').value.trim();
            const parts = val.split(' ').filter(Boolean);
            const inits = parts.length >= 2
                ? (parts[0][0] + parts[parts.length - 1][0]).toUpperCase()
                : (parts[0] ? parts[0].slice(0, 2).toUpperCase() : '?');
            
            document.getElementById('js-avatar').textContent = inits;
            document.getElementById('js-name').textContent = val || 'New Member';
        }
    </script>
}