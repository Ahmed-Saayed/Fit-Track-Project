@model FitTrack_Pro.ViewModels.AssignPlanViewModel

@{
    ViewData["Title"] = "Assign Plan";
}

<div class="container-fluid px-0 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">Assign Subscription Plan</h2>
            <p class="text-muted mb-0">Select a premium plan for <span class="text-primary fw-bold">@Model.MemberName</span></p>
        </div>
        <div>
            <a asp-action="Details" asp-route-id="@Model.MemberId" class="btn btn-outline-primary rounded-pill px-4 shadow-sm">
                <i class="fas fa-arrow-left me-2"></i>Back to Details
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="card-body p-4 p-md-5">
            <div class="row g-5">

                <div class="col-md-5 border-end border-light pe-md-5">
                    <div class="mb-4">
                        <label class="text-primary small text-uppercase fw-bold tracking-wider mb-2 d-block">Member Details</label>
                        <h3 class="text-dark fw-bold">@Model.MemberName</h3>
                    </div>

                    @if (Model.CurrentPlanName != null)
                    {
                        <div class="bg-light border rounded-4 p-4 mb-4 shadow-sm">
                            <label class="text-muted small text-uppercase fw-bold mb-2 d-block">Current Active Plan</label>
                            <h5 class="text-primary fw-bold mb-1">@Model.CurrentPlanName</h5>
                            <p class="text-dark small mb-0">
                                <i class="far fa-calendar-alt me-1 text-primary"></i>
                                Expires on: <strong>@Model.CurrentPlanEndDate?.ToString("MMM dd, yyyy")</strong>
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="bg-warning bg-opacity-10 border border-warning border-opacity-25 rounded-4 p-4 mb-4">
                            <p class="text-warning-emphasis small mb-0 fw-medium">
                                <i class="fas fa-exclamation-triangle me-2"></i> No active plan currently assigned.
                            </p>
                        </div>
                    }

                    <div class="p-3 bg-primary bg-opacity-10 rounded-3">
                        <ul class="list-unstyled mb-0 small text-dark">
                            <li class="mb-2"><i class="fas fa-check-circle text-primary me-2"></i> New assignment will replace current plan.</li>
                            <li><i class="fas fa-check-circle text-primary me-2"></i> End date is calculated automatically.</li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-7 ps-md-5">
                    <h5 class="fw-bold mb-4 text-dark">Subscription Settings</h5>

                    <form asp-action="AssignPlan" method="post" class="needs-validation">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="MemberId" />
                        <input type="hidden" asp-for="MemberName" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="mb-4">
                            <label asp-for="SelectedPlanId" class="form-label text-dark fw-bold small text-uppercase">Choose New Plan</label>
                            <select asp-for="SelectedPlanId" id="SelectedPlanId" class="form-select form-select-lg border-2 shadow-sm" required>
                                <option value="">-- Click a plan card or select here --</option>
                                @foreach (var plan in Model.AvailablePlans)
                                {
                                    <option value="@plan.Id">@plan.Name — @plan.Price.ToString("N0") EGP (@plan.DurationInDays Days)</option>
                                }
                            </select>
                            <span asp-validation-for="SelectedPlanId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="StartDate" class="form-label text-dark fw-bold small text-uppercase">Subscription Start Date</label>
                            <input asp-for="StartDate" class="form-control form-control-lg border-2 shadow-sm" type="date" required />
                            <span asp-validation-for="StartDate" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-grid gap-3 pt-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow">
                                <i class="fas fa-check-circle me-2"></i> Confirm & Assign Plan
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.MemberId" class="btn btn-link text-muted fw-medium text-decoration-none">Cancel Assignment</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <h5 class="fw-bold text-dark mb-4"><i class="fas fa-th-large me-2 text-primary"></i>Quick Select Plans</h5>
        <div class="row g-4">
            @foreach (var plan in Model.AvailablePlans)
            {
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 plan-card"
                         onclick="selectPlan('@plan.Id')">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="fw-bold mb-0 text-dark">@plan.Name</h5>
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">@plan.DurationInDays Days</span>
                            </div>
                            <h3 class="fw-bold text-primary mb-3">@plan.Price.ToString("N0") <small class="fs-6 text-muted">EGP</small></h3>
                            <p class="text-muted small mb-0 line-clamp">@plan.Description</p>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-4 px-4">
                            <button type="button" class="btn btn-outline-primary btn-sm rounded-pill w-100 fw-bold">Select This Plan</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function selectPlan(planId) {
            document.getElementById('SelectedPlanId').value = planId;
            // Add a subtle visual feedback
            window.scrollTo({ top: 100, behavior: 'smooth' });
        }
    </script>
    <style>
        body {
            background-color: #f8f9fa;
        }

        .rounded-4 {
            border-radius: 1.2rem !important;
        }

        .plan-card {
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid transparent !important;
            background: #fff;
        }

            .plan-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 15px 30px rgba(13, 110, 253, 0.1) !important;
                border-color: #0d6efd !important;
            }

        .form-select, .form-control {
            border-color: #dee2e6;
        }

            .form-select:focus, .form-control:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.05);
            }

        .line-clamp {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
}