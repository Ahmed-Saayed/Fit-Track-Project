@model FitTrack_Pro.ViewModels.MemberDashboardViewModel

@{
    ViewData["Title"] = "My Dashboard";
    Layout = "_Layout";
}

<div class="dashboard-wrapper py-5">
    <div class="container">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h6 class="text-primary fw-bold text-uppercase mb-2 tracking-widest">Welcome Back</h6>
                <h1 class="display-5 fw-black text-dark mb-0">@Model.FullName</h1>
            </div>
            <div class="text-end d-none d-md-block">
                <p class="text-muted small mb-1">Membership ID</p>
                <div class="badge bg-white shadow-sm border p-2 px-3 rounded-pill">
                    <code class="text-primary">@Model.Barcode</code>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Left Column: Personal Info & Subscription -->
            <div class="col-lg-4">
                <div class="card bg-white border-0 shadow-sm rounded-4 p-4 h-100">
                    <h5 class="text-dark fw-bold mb-4 border-bottom pb-3">
                        <i class="fas fa-user-circle me-2 text-primary"></i>Profile Info
                    </h5>
                    
                    <div class="mb-4">
                        <label class="text-muted small text-uppercase fw-bold mb-1">Phone Number</label>
                        <p class="text-dark fs-5 mb-0">@Model.PhoneNumber</p>
                    </div>
                    
                    <div class="mb-4">
                        <label class="text-muted small text-uppercase fw-bold mb-1">Age</label>
                        <p class="text-dark fs-5 mb-0">@Model.Age Years</p>
                    </div>

                    <div class="mt-auto">
                        <h5 class="text-dark fw-bold mb-4 border-bottom pb-3 pt-4">
                            <i class="fas fa-crown me-2 text-warning"></i>Active Plan
                        </h5>
                        
                        @if (Model.ActiveSubscription != null)
                        {
                            <div class="bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-3 p-3">
                                <h4 class="text-primary fw-black mb-1">@Model.ActiveSubscription.PlanName</h4>
                                <p class="text-muted small mb-3">Expires on @Model.ActiveSubscription.EndDate.ToString("MMM dd, yyyy")</p>
                                
                                <div class="progress bg-white rounded-pill mb-2" style="height: 6px;">
                                    @{
                                        var total = (Model.ActiveSubscription.EndDate - Model.ActiveSubscription.StartDate).TotalDays;
                                        var remaining = (Model.ActiveSubscription.EndDate - DateTime.Today).TotalDays;
                                        var percent = total > 0 ? (remaining / total) * 100 : 0;
                                        percent = Math.Max(0, Math.Min(100, percent));
                                    }
                                    <div class="progress-bar bg-primary rounded-pill" style="width: @percent%"></div>
                                </div>
                                <div class="d-flex justify-content-between small">
                                    <span class="text-muted">Status</span>
                                    <span class="text-success fw-bold">Active</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-light bg-light border-0 text-muted rounded-3 mb-0">
                                <i class="fas fa-exclamation-triangle me-2"></i>No active plan found.
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right Column: Recent Classes -->
            <div class="col-lg-8">
                <div class="card bg-white border-0 shadow-sm rounded-4 h-100">
                    <div class="card-header bg-transparent border-0 p-4 pb-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="text-dark fw-bold mb-0">
                                <i class="fas fa-dumbbell me-2 text-primary"></i>My Attended Classes
                            </h5>
                            <span class="badge bg-primary rounded-pill px-3">@Model.AttendedClasses.Count() Total</span>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        @if (Model.AttendedClasses.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="text-muted small text-uppercase font-secondary">
                                        <tr>
                                            <th class="border-0 py-3">Class Name</th>
                                            <th class="border-0 py-3">Trainer</th>
                                            <th class="border-0 py-3">Date</th>
                                            <th class="border-0 py-3">Duration</th>
                                        </tr>
                                    </thead>
                                    <tbody class="border-top-0">
                                        @foreach (var item in Model.AttendedClasses)
                                        {
                                            <tr>
                                                <td class="py-3 border-light">
                                                    <span class="text-dark fw-bold">@item.ClassName</span>
                                                </td>
                                                <td class="py-3 border-light text-muted">@item.TrainerName</td>
                                                <td class="py-3 border-light text-muted">@item.AttendanceDate.ToString("MMM dd, yyyy HH:mm")</td>
                                                <td class="py-3 border-light">
                                                    <span class="badge bg-light text-primary border">@item.DurationInMinutes min</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <div class="mb-3">
                                    <i class="fas fa-calendar-times fs-1 text-muted opacity-25"></i>
                                </div>
                                <h6 class="text-muted">No attendance records found yet.</h6>
                                <p class="text-muted small">Join a class today to start your journey!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8fafc; color: #1e293b; }
    .dashboard-wrapper { min-height: 100vh; background: #f8fafc; }
    .fw-black { font-weight: 900; }
    .tracking-widest { letter-spacing: 0.2em; }
    .rounded-4 { border-radius: 1.25rem !important; }
    .font-secondary { font-family: 'Syne', sans-serif; }
    .text-primary { color: #3b82f6 !important; }
    .bg-primary { background-color: #3b82f6 !important; }
    .btn-primary { background-color: #3b82f6; border-color: #3b82f6; }
    .btn-primary:hover { background-color: #2563eb; border-color: #2563eb; transform: translateY(-2px); }
    .card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.05) !important; }
    .border-light { border-color: #f1f5f9 !important; }
</style>
