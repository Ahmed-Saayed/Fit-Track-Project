@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger shadow-sm">
                <div class="card-body py-5">
                    <div class="mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-danger bi bi-shield-lock" viewBox="0 0 16 16">
                            <path d="M5.338 1.59a.5.5 0 0 1 .42.067c.738.496 1.444.76 2.242.76.8 0 1.504-.264 2.242-.76a.5.5 0 0 1 .84.39v3.011c0 2.891-1.128 5.738-3.082 8.054a.5.5 0 0 1-.776 0C5.128 9.341 4 6.494 4 3.601V.98a.5.5 0 0 1 .338-.472zM6.78 10.582a4.484 4.484 0 0 0 1.22.758c.414-.191.826-.443 1.22-.758C10.687 9.176 11.5 7.18 11.5 5.011V2.63c-.704.381-1.442.63-2.338.63-.896 0-1.634-.249-2.338-.63v2.38c0 2.17.813 4.166 2.124 5.572z"/>
                            <path d="M9.5 6a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm-1 2a.5.5 0 0 1 .5.5v1.5a.5.5 0 0 1-1 0v-1.5a.5.5 0 0 1 .5-.5z"/>
                        </svg>
                    </div>
                    <h1 class="display-4 text-danger font-syne mb-3">Access Denied</h1>
                    <p class="lead text-muted mb-4">You do not have permission to view this resource.</p>
                    <hr class="my-4">
                    <p class="mb-5">If you believe this is an error, please contact your system administrator.</p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="/" class="btn btn-outline-secondary px-4">
                            Go to Home
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger px-4">Log Out</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .font-syne {
        font-family: 'Syne', sans-serif;
        font-weight: 600;
    }
</style>
