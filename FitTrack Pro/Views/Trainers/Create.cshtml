@model FitTrack_Pro.ViewModels.TrainerFormViewModel
@{
    var isEdit = Model.Id != 0;
    ViewData["Title"] = isEdit ? "Edit Trainer" : "Add Trainer";

    var nameParts = Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var initials = nameParts.Length >= 2
        ? $"{nameParts[0][0]}{nameParts[^1][0]}"
        : (nameParts.Length == 1 && nameParts[0].Length > 0 ? nameParts[0][..Math.Min(2, nameParts[0].Length)] : "?");
    initials = initials.ToUpper();
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=Syne:wght@500;600&display=swap" rel="stylesheet">

<style>
    .f-wrap {
        font-family: 'DM Sans',sans-serif;
    }

    .f-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 1.75rem;
    }

        .f-breadcrumb a {
            color: #1a56db;
            text-decoration: none;
        }

            .f-breadcrumb a:hover {
                text-decoration: underline;
            }

    .f-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 1.75rem;
    }

        .f-page-header h1 {
            font-family: 'Syne',sans-serif;
            font-size: 22px;
            font-weight: 600;
            letter-spacing: -.3px;
            margin: 0;
        }

        .f-page-header p {
            font-size: 13px;
            color: #6b7280;
            margin: 3px 0 0;
        }

    .f-id-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #e8effe;
        color: #185FA5;
        font-size: 12px;
        font-weight: 500;
        padding: 4px 10px;
        border-radius: 20px;
        border: 0.5px solid #B5D4F4;
        white-space: nowrap;
        align-self: flex-start;
    }

    .f-layout {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 20px;
        align-items: start;
    }

    @@media (max-width:680px) {
        .f-layout {
            grid-template-columns: 1fr;
        }
    }

    /* Profile sidebar */
    .f-profile {
        background: #fff;
        border: 0.5px solid #e5e7eb;
        border-radius: 12px;
        padding: 1.25rem 1rem;
        text-align: center;
    }

    .f-avatar {
        width: 68px;
        height: 68px;
        border-radius: 50%;
        background: #e8effe;
        border: 2px solid #B5D4F4;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 10px;
        font-family: 'Syne',sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: #185FA5;
    }

    .f-profile-name {
        font-family: 'Syne',sans-serif;
        font-size: 14px;
        font-weight: 600;
        margin: 0;
    }

    .f-profile-phone {
        font-size: 12px;
        color: #6b7280;
        margin: 3px 0 0;
    }

    .f-chip {
        display: inline-block;
        margin-top: 8px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
        background: #f3f4f6;
        color: #6b7280;
        border: 0.5px solid #e5e7eb;
    }

    .f-meta {
        margin-top: 14px;
        border-top: 0.5px solid #e5e7eb;
        padding-top: 12px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        text-align: left;
    }

    .f-meta-row {
        display: flex;
        gap: 6px;
        font-size: 12px;
    }

    .f-meta-lbl {
        color: #9ca3af;
        flex-shrink: 0;
        width: 65px;
    }

    .f-meta-val {
        font-weight: 500;
        overflow-wrap: anywhere;
        color: #111827;
    }

    /* Form card */
    .f-card {
        background: #fff;
        border: 0.5px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
    }

    .f-card-header {
        padding: 13px 20px;
        border-bottom: 0.5px solid #e5e7eb;
        background: #f9fafb;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .f-card-header svg {
            width: 15px;
            height: 15px;
            stroke: #1a56db;
            flex-shrink: 0;
        }

    .f-card-title {
        font-family: 'Syne',sans-serif;
        font-size: 14px;
        font-weight: 500;
        margin: 0;
    }

    .f-card-body {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    /* Fields */
    .f-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

        .f-row.full {
            grid-template-columns: 1fr;
        }

    @@media (max-width:560px) {
        .f-row {
            grid-template-columns: 1fr;
        }
    }

    .f-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .f-field > label {
            font-size: 11px;
            font-weight: 500;
            color: #6b7280;
            letter-spacing: .4px;
            text-transform: uppercase;
        }

    .f-iw {
        position: relative;
    }

    .f-ico {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        width: 14px;
        height: 14px;
        stroke: #9ca3af;
        pointer-events: none;
    }

    .f-iw input, .f-iw select, .f-iw textarea {
        width: 100%;
        background: #fff;
        border: 0.5px solid #d1d5db;
        border-radius: 8px;
        padding: 9px 12px 9px 32px;
        font-family: 'DM Sans',sans-serif;
        font-size: 14px;
        color: #111827;
        transition: border-color .15s,box-shadow .15s;
        outline: none;
        -webkit-appearance: none;
        appearance: none;
    }

        .f-iw input:focus, .f-iw select:focus, .f-iw textarea:focus {
            border-color: #1a56db;
            box-shadow: 0 0 0 3px rgba(26,86,219,.1);
        }

    .f-iw input.is-invalid {
        border-color: #e24b4a;
        box-shadow: 0 0 0 3px rgba(226,75,74,.08);
    }

    .f-hint {
        font-size: 11px;
        color: #9ca3af;
        margin-top: 1px;
    }

    .f-err {
        font-size: 11px;
        color: #e24b4a;
    }

    /* Divider */
    .f-divider {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #9ca3af;
        font-size: 11px;
        letter-spacing: .5px;
        text-transform: uppercase;
    }

        .f-divider::before, .f-divider::after {
            content: '';
            flex: 1;
            height: 0.5px;
            background: #e5e7eb;
        }

    /* Danger zone */
    .f-danger {
        background: #fcebeb;
        border: 0.5px solid #F7C1C1;
        border-radius: 8px;
        padding: 12px 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .f-danger-title {
        font-size: 13px;
        font-weight: 500;
        color: #A32D2D;
        margin: 0;
    }

    .f-danger-desc {
        font-size: 12px;
        color: #791F1F;
        margin: 3px 0 0;
    }

    .f-btn-del {
        background: transparent;
        border: 0.5px solid #e24b4a;
        border-radius: 8px;
        padding: 7px 14px;
        font-family: 'DM Sans',sans-serif;
        font-size: 13px;
        font-weight: 500;
        color: #e24b4a;
        cursor: pointer;
        transition: background .15s;
    }

        .f-btn-del:hover {
            background: rgba(226,75,74,.08);
        }

    /* Footer */
    .f-footer {
        padding: 13px 20px;
        border-top: 0.5px solid #e5e7eb;
        background: #f9fafb;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
    }

    .f-btn {
        padding: 8px 18px;
        border-radius: 8px;
        font-family: 'DM Sans',sans-serif;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all .15s;
        border: 0.5px solid transparent;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
    }

        .f-btn svg {
            width: 14px;
            height: 14px;
            flex-shrink: 0;
        }

    .f-btn-ghost {
        background: transparent;
        border-color: #d1d5db;
        color: #6b7280;
    }

        .f-btn-ghost:hover {
            background: #f3f4f6;
            color: #111827;
        }

    .f-btn-primary {
        background: #1a56db;
        border-color: #1a56db;
        color: #fff;
    }

        .f-btn-primary:hover {
            filter: brightness(1.08);
        }

        .f-btn-primary:active {
            transform: scale(.98);
        }
</style>

<div class="f-wrap">

    <div class="f-breadcrumb">
        <a asp-action="Index">Trainers</a>
        <span>›</span>
        @if (isEdit)
        {
            <a asp-action="Details" asp-route-id="@Model.Id">@Model.FullName</a>
            <span>›</span>
            <span>Edit</span>
        }
        else
        {
            <span>Add trainer</span>
        }
    </div>

    <div class="f-page-header">
        <div>
            <h1>@(isEdit ? "Edit trainer" : "Add new trainer")</h1>
            <p>@(isEdit ? "Update trainer information" : "Fill in the form below to register a new trainer")</p>
        </div>
        @if (isEdit)
        {
            <div class="f-id-badge">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"
                     style="width:12px;height:12px">
                    <rect x="2" y="3" width="12" height="10" rx="2" />
                    <path d="M5 7h6M5 10h4" />
                </svg>
                Trainer #@Model.Id
            </div>
        }
    </div>

    <div class="f-layout">

        <div class="f-profile">
            <div class="f-avatar" id="js-avatar">@initials</div>
            <p class="f-profile-name" id="js-name">@(string.IsNullOrWhiteSpace(Model.FullName) ? "New trainer" : Model.FullName)</p>
            <p class="f-profile-phone" id="js-phone">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "—" : Model.PhoneNumber)</p>
            <div class="f-chip">@(isEdit ? "Editing" : "New")</div>
            <div class="f-meta">
                <div class="f-meta-row">
                    <span class="f-meta-lbl">Specialty</span>
                    <span class="f-meta-val" id="js-specialty">@(string.IsNullOrWhiteSpace(Model.Specialty) ? "—" : Model.Specialty)</span>
                </div>
                <div class="f-meta-row">
                    <span class="f-meta-lbl">Salary / %</span>
                    <span class="f-meta-val" id="js-salary">@(Model.SalaryOrPercentage > 0 ? Model.SalaryOrPercentage.ToString("N0") : "—")</span>
                </div>
            </div>
        </div>

        <div class="f-card">
            <div class="f-card-header">
                <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5">
                    @if (isEdit)
                    {
                        <text><path d="M10 2l4 4-7 7H3v-4l7-7z" /></text>
                    }
                    else
                    {
                        <text><path d="M8 3v10M3 8h10" /></text>
                    }
                </svg>
                <span class="f-card-title">Trainer information</span>
            </div>

            <form asp-action="@(isEdit ? "Edit" : "Create")" method="post"
                  id="trainerForm" class="f-card-body" novalidate>
                @Html.AntiForgeryToken()
                @if (isEdit)
                {
                    <input asp-for="Id" type="hidden" />
                }

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger small rounded" role="alert"></div>

                <div class="f-row full">
                    <div class="f-field">
                        <label asp-for="FullName">Full name</label>
                        <div class="f-iw">
                            <svg class="f-ico" viewBox="0 0 16 16" fill="none" stroke-width="1.5">
                                <circle cx="8" cy="5" r="3" />
                                <path d="M2 13c0-3 2.5-5 6-5s6 2 6 5" />
                            </svg>
                            <input asp-for="FullName" id="inp-name"
                                   class="@(ViewData.ModelState["FullName"]?.Errors.Any() == true ? "is-invalid" : "")"
                                   placeholder="e.g. John Smith" autocomplete="name"
                                   oninput="syncPreview()" />
                        </div>
                        <span asp-validation-for="FullName" class="f-err"></span>
                    </div>
                </div>

                <div class="f-row">
                    <div class="f-field">
                        <label asp-for="PhoneNumber">Phone number</label>
                        <div class="f-iw">
                            <svg class="f-ico" viewBox="0 0 16 16" fill="none" stroke-width="1.5">
                                <path d="M3 2h3l1.5 3.5-2 1.5a9 9 0 003.5 3.5l1.5-2L14 12v3a1 1 0 01-1 1A12 12 0 012 3a1 1 0 011-1z" />
                            </svg>
                            <input asp-for="PhoneNumber" id="inp-phone" placeholder="01X XXX XXXX"
                                   oninput="document.getElementById('js-phone').textContent=this.value||'—'" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="f-err"></span>
                    </div>
                    <div class="f-field">
                        <label asp-for="Specialty">Specialty</label>
                        <div class="f-iw">
                            <svg class="f-ico" viewBox="0 0 16 16" fill="none" stroke-width="1.5">
                                <path d="M8 1l2 3h3l-2.5 2.5L11.5 10 8 8 4.5 10l1-3.5L3 4h3l2-3z" />
                            </svg>
                            <input asp-for="Specialty" id="inp-specialty" placeholder="e.g. Weightlifting, Yoga"
                                   oninput="document.getElementById('js-specialty').textContent=this.value||'—'" />
                        </div>
                        <span asp-validation-for="Specialty" class="f-err"></span>
                    </div>
                </div>

                <div class="f-row">
                    <div class="f-field">
                        <label asp-for="SalaryOrPercentage">Salary / Percentage</label>
                        <div class="f-iw">
                            <svg class="f-ico" viewBox="0 0 16 16" fill="none" stroke-width="1.5">
                                <path d="M8 1v14M5 4c0-1 1-2 3-2s3 1 3 2-1 2-3 2-3 1-3 2 1 2 3 2 3-1 3-2" />
                            </svg>
                            <input asp-for="SalaryOrPercentage" type="number" step="0.01" min="0"
                                   id="inp-salary" placeholder="e.g. 5000"
                                   oninput="document.getElementById('js-salary').textContent=this.value||'—'" />
                        </div>
                        <span class="f-hint">Monthly salary or commission percentage</span>
                        <span asp-validation-for="SalaryOrPercentage" class="f-err"></span>
                    </div>
                </div>

                @* Danger zone — only shown in edit mode *@
                @if (isEdit)
                {
                    <div class="f-divider">Danger zone</div>
                    <div class="f-danger">
                        <div>
                            <p class="f-danger-title">Remove this trainer</p>
                            <p class="f-danger-desc">Soft delete — all data is retained and recoverable.</p>
                        </div>
                        <button type="button" class="f-btn-del"
                                data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
                            Remove trainer
                        </button>
                    </div>
                }

            </form>

            <div class="f-footer">
                @if (isEdit)
                {
                    <a asp-action="Details" asp-route-id="@Model.Id" class="f-btn f-btn-ghost">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 3L5 8l5 5" /></svg>
                        Discard
                    </a>
                }
                else
                {
                    <a asp-action="Index" class="f-btn f-btn-ghost">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 3L5 8l5 5" /></svg>
                        Cancel
                    </a>
                }
                <button type="submit" form="trainerForm" class="f-btn f-btn-primary">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M13 3l-6 8-4-4" />
                    </svg>
                    @(isEdit ? "Save changes" : "Add trainer")
                </button>
            </div>
        </div>

    </div>
</div>

@* Delete modal (edit mode only) *@
@if (isEdit)
{
    <div class="modal fade" id="confirmDeleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border:0.5px solid #e5e7eb;border-radius:12px;font-family:'DM Sans',sans-serif">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title" style="font-family:'Syne',sans-serif;font-size:16px;color:#A32D2D">Confirm removal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="font-size:14px;color:#374151">
                    Are you sure you want to remove <strong>@Model.FullName</strong>?
                    <br><span style="font-size:12px;color:#9ca3af">Soft delete — the record can be recovered later.</span>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="f-btn f-btn-ghost" style="font-size:13px" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="Delete" asp-controller="Trainers" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="f-btn f-btn-primary"
                                style="background:#e24b4a;border-color:#e24b4a;font-size:13px">
                            Remove trainer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function syncPreview() {
            const val    = document.getElementById('inp-name').value.trim();
            const parts  = val.split(' ').filter(Boolean);
            const inits  = parts.length >= 2
                ? (parts[0][0] + parts[parts.length-1][0]).toUpperCase()
                : (parts[0] ? parts[0].slice(0,2).toUpperCase() : '?');
            document.getElementById('js-avatar').textContent = inits;
            document.getElementById('js-name').textContent   = val || 'New trainer';
        }
    </script>
}
