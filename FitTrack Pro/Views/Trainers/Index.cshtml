@model FitTrack_Pro.ViewModels.TrainerIndexViewModel
@{
    ViewData["Title"] = "Trainers";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=Syne:wght@500;600&display=swap" rel="stylesheet">

<style>
    .m-wrap { font-family:'DM Sans',sans-serif; }
    .m-header { display:flex; align-items:flex-start; justify-content:space-between;
        flex-wrap:wrap; gap:12px; margin-bottom:1.75rem; }
    .m-header h1 { font-family:'Syne',sans-serif; font-size:22px; font-weight:600;
        letter-spacing:-.3px; margin:0; }
    .m-header p { font-size:13px; color:#6b7280; margin:3px 0 0; }
    .m-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
        gap:12px; margin-bottom:1.75rem; }
    .m-stat { background:#f9fafb; border:0.5px solid #e5e7eb;
        border-radius:10px; padding:14px 16px; }
    .m-stat-label { font-size:11px; font-weight:500; color:#9ca3af;
        letter-spacing:.5px; text-transform:uppercase; margin:0 0 6px; }
    .m-stat-val { font-family:'Syne',sans-serif; font-size:24px; font-weight:600; margin:0; line-height:1; }
    .c-blue  { color:#1a56db; } .c-green { color:#3B6D11; }
    .c-amber { color:#BA7517; } .c-red   { color:#A32D2D; }
    .m-toolbar { background:#fff; border:0.5px solid #e5e7eb; border-radius:10px;
        padding:12px 16px; display:flex; align-items:center;
        gap:10px; flex-wrap:wrap; margin-bottom:16px; }
    .m-search-wrap { position:relative; flex:1; min-width:200px; }
    .m-search-wrap svg { position:absolute; left:10px; top:50%;
        transform:translateY(-50%); width:14px; height:14px; stroke:#9ca3af; }
    .m-search-wrap input { width:100%; background:#f9fafb; border:0.5px solid #e5e7eb;
        border-radius:8px; padding:8px 12px 8px 32px; font-family:'DM Sans',sans-serif;
        font-size:14px; color:#111827; outline:none;
        transition:border-color .15s,box-shadow .15s; }
    .m-search-wrap input:focus { border-color:#1a56db;
        box-shadow:0 0 0 3px rgba(26,86,219,.1); background:#fff; }
    .m-btn { padding:8px 16px; border-radius:8px; font-family:'DM Sans',sans-serif;
        font-size:13px; font-weight:500; cursor:pointer; transition:all .15s;
        border:0.5px solid transparent; display:inline-flex; align-items:center;
        gap:6px; text-decoration:none; white-space:nowrap; }
    .m-btn svg { width:13px; height:13px; flex-shrink:0; }
    .m-btn-primary { background:#1a56db; border-color:#1a56db; color:#fff; }
    .m-btn-primary:hover { filter:brightness(1.08); color:#fff; }
    .m-btn-ghost  { background:transparent; border-color:#d1d5db; color:#6b7280; }
    .m-btn-ghost:hover  { background:#f3f4f6; color:#111827; }
    .m-btn-clear  { background:transparent; border-color:#e5e7eb; color:#9ca3af;
        font-size:12px; padding:7px 12px; }
    .m-btn-clear:hover  { background:#f9fafb; color:#374151; }
    .m-card { background:#fff; border:0.5px solid #e5e7eb; border-radius:12px; overflow:hidden; }
    .m-table-wrap { overflow-x:auto; }
    .m-table { width:100%; border-collapse:collapse; font-size:13px; }
    .m-table thead tr { background:#f9fafb; border-bottom:0.5px solid #e5e7eb; }
    .m-table th { padding:10px 16px; font-size:11px; font-weight:500; color:#9ca3af;
        letter-spacing:.5px; text-transform:uppercase; white-space:nowrap; text-align:left; }
    .m-table td { padding:12px 16px; border-bottom:0.5px solid #f3f4f6;
        color:#111827; vertical-align:middle; }
    .m-table tbody tr:last-child td { border-bottom:none; }
    .m-table tbody tr:hover td { background:#fafafa; }
    .m-name { font-family:'Syne',sans-serif; font-weight:500; font-size:13px;
        color:#111827; text-decoration:none; }
    .m-name:hover { color:#1a56db; }
    .m-muted { color:#9ca3af; font-size:12px; }
    .m-badge { display:inline-flex; align-items:center; padding:3px 8px;
        border-radius:20px; font-size:11px; font-weight:500; white-space:nowrap; }
    .m-badge-specialty { background:#e8effe; color:#185FA5; border:0.5px solid #B5D4F4; }
    .m-actions { display:flex; gap:5px; justify-content:flex-end; }
    .m-act { width:30px; height:30px; border-radius:7px; display:flex;
        align-items:center; justify-content:center; border:0.5px solid #e5e7eb;
        background:transparent; cursor:pointer; transition:all .15s;
        color:#6b7280; text-decoration:none; }
    .m-act svg { width:13px; height:13px; }
    .m-act:hover { background:#f3f4f6; color:#111827; border-color:#d1d5db; }
    .m-act.del:hover { background:#fcebeb; color:#e24b4a; border-color:#F7C1C1; }
    .m-empty { padding:48px 24px; text-align:center; }
    .m-empty-icon { width:44px; height:44px; margin:0 auto 14px; background:#f3f4f6;
        border-radius:50%; display:flex; align-items:center; justify-content:center; }
    .m-empty-icon svg { width:20px; height:20px; stroke:#9ca3af; }
    .m-empty h3 { font-family:'Syne',sans-serif; font-size:15px; font-weight:600; margin:0 0 6px; }
    .m-empty p  { font-size:13px; color:#6b7280; margin:0; }
    .m-tfoot { padding:12px 16px; border-top:0.5px solid #e5e7eb; background:#f9fafb;
        display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; }
    .m-page-info { font-size:12px; color:#9ca3af; }
    .m-pager { display:flex; gap:4px; }
    .m-pager a { width:30px; height:30px; border-radius:7px; display:flex;
        align-items:center; justify-content:center; border:0.5px solid #e5e7eb;
        background:transparent; font-size:13px; font-weight:500; cursor:pointer;
        text-decoration:none; color:#374151; transition:all .15s; }
    .m-pager a:hover { background:#f3f4f6; border-color:#d1d5db; }
    .m-pager a.act { background:#1a56db; border-color:#1a56db; color:#fff; }
    .m-pager a.off { opacity:.35; pointer-events:none; }
    .m-alert { padding:10px 14px; border-radius:8px; font-size:13px;
        display:flex; align-items:center; gap:8px; margin-bottom:16px; }
    .m-alert svg { width:14px; height:14px; flex-shrink:0; }
    .m-alert-ok  { background:#EAF3DE; color:#3B6D11; border:0.5px solid #C0DD97; }
    .m-alert-err { background:#fcebeb;  color:#A32D2D; border:0.5px solid #F7C1C1; }
</style>

<div class="m-wrap">

    @if (TempData["Success"] is string ok)
    {
        <div class="m-alert m-alert-ok">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 3l-6 8-4-4" /></svg>
            @ok
        </div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="m-alert m-alert-err">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6" /><path d="M8 5v3M8 11h.01" /></svg>
            @err
        </div>
    }

    <div class="m-header">
        <div>
            <h1>Trainers</h1>
            <p>@Model.TotalCount trainers in the system</p>
        </div>
        <a asp-action="Create" class="m-btn m-btn-primary">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 3v10M3 8h10" /></svg>
            Add trainer
        </a>
    </div>

    <div class="m-stats">
        <div class="m-stat">
            <p class="m-stat-label">Total</p>
            <p class="m-stat-val c-blue">@Model.TotalCount</p>
        </div>
        <div class="m-stat">
            <p class="m-stat-label">This Page</p>
            <p class="m-stat-val c-green">@Model.Trainers.Count()</p>
        </div>
    </div>

    <form asp-action="Index" method="get">
        <div class="m-toolbar">
            <div class="m-search-wrap">
                <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5"><circle cx="7" cy="7" r="4.5" /><path d="M10.5 10.5l3 3" /></svg>
                <input type="text" name="search" value="@Model.SearchQuery"
                       placeholder="Search by name, phone or specialty..." />
            </div>
            <button type="submit" class="m-btn m-btn-ghost">Search</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <a asp-action="Index" class="m-btn m-btn-clear">Clear</a>
            }
        </div>
    </form>

    <div class="m-card">
        <div class="m-table-wrap">
            <table class="m-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Specialty</th>
                        <th>Salary / %</th>
                        <th>Classes</th>
                        <th style="text-align:right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Trainers.Any())
                    {
                        <tr>
                            <td colspan="7">
                                <div class="m-empty">
                                    <div class="m-empty-icon">
                                        <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5">
                                            <path d="M3 12a5 5 0 1110 0M6 6a2 2 0 104 0 2 2 0 00-4 0" />
                                        </svg>
                                    </div>
                                    <h3>No trainers found</h3>
                                    <p>@(string.IsNullOrWhiteSpace(Model.SearchQuery) ? "Get started by adding your first trainer." : $"No results for \"{Model.SearchQuery}\" — try a different search.")</p>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var t in Model.Trainers)
                    {
                        <tr>
                            <td><span class="m-muted">@t.Id</span></td>
                            <td><a asp-action="Details" asp-route-id="@t.Id" class="m-name">@t.FullName</a></td>
                            <td style="color:#374151">@t.PhoneNumber</td>
                            <td>
                                <span class="m-badge m-badge-specialty">@t.Specialty</span>
                            </td>
                            <td style="font-weight:500;color:#374151">@t.SalaryOrPercentage.ToString("N0")</td>
                            <td style="color:#374151">@t.ClassCount</td>
                            <td>
                                <div class="m-actions">
                                    <a asp-action="Details" asp-route-id="@t.Id" class="m-act" title="View">
                                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" />
                                            <circle cx="8" cy="8" r="2" />
                                        </svg>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@t.Id" class="m-act" title="Edit">
                                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M10 2l4 4-7 7H3v-4l7-7z" />
                                        </svg>
                                    </a>
                                    <button type="button" class="m-act del" title="Delete"
                                            data-bs-toggle="modal" data-bs-target="#deleteModal"
                                            data-id="@t.Id" data-name="@t.FullName">
                                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M3 4h10M6 4V2h4v2M5 4v9a1 1 0 001 1h4a1 1 0 001-1V4" />
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalCount > 0)
        {
            <div class="m-tfoot">
                <span class="m-page-info">
                    Showing @((Model.CurrentPage - 1) * Model.PageSize + 1)–@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount))
                    of @Model.TotalCount
                </span>
                <div class="m-pager">
                    <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-search="@Model.SearchQuery"
                       class="@(!Model.HasPrevious ? "off" : "")">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" style="width:12px;height:12px">
                            <path d="M10 3L5 8l5 5" />
                        </svg>
                    </a>
                    @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                    {
                        <a asp-action="Index" asp-route-page="@i"
                           asp-route-search="@Model.SearchQuery"
                           class="@(i == Model.CurrentPage ? "act" : "")">@i</a>
                    }
                    <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-search="@Model.SearchQuery"
                       class="@(!Model.HasNext ? "off" : "")">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" style="width:12px;height:12px">
                            <path d="M6 3l5 5-5 5" />
                        </svg>
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border:0.5px solid #e5e7eb;border-radius:12px;font-family:'DM Sans',sans-serif">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title" style="font-family:'Syne',sans-serif;font-size:16px;color:#A32D2D">Confirm deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="font-size:14px;color:#374151">
                Are you sure you want to remove <strong id="del-name"></strong>?
                <br><span style="font-size:12px;color:#9ca3af">Soft delete — data is retained and recoverable.</span>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button class="m-btn m-btn-ghost" data-bs-dismiss="modal" style="font-size:13px">Cancel</button>
                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="del-id" name="id" />
                    <button type="submit" class="m-btn m-btn-primary"
                            style="background:#e24b4a;border-color:#e24b4a;font-size:13px">
                        Remove trainer
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('deleteModal').addEventListener('show.bs.modal', e => {
            document.getElementById('del-name').textContent = e.relatedTarget.dataset.name;
            document.getElementById('del-id').value = e.relatedTarget.dataset.id;
        });
    </script>
}
