@model FitTrack_Pro.ViewModels.TrainerDetailsViewModel
@{
    ViewData["Title"] = Model.FullName;
    var nameParts = Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var initials = nameParts.Length >= 2
        ? $"{nameParts[0][0]}{nameParts[^1][0]}" : (nameParts.Length == 1 ? nameParts[0][..Math.Min(2, nameParts[0].Length)] : "?");
    initials = initials.ToUpper();
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=Syne:wght@500;600&display=swap" rel="stylesheet">

<style>
    .d-wrap {
        font-family: 'DM Sans',sans-serif;
    }

    .d-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 1.75rem;
    }

        .d-breadcrumb a {
            color: #1a56db;
            text-decoration: none;
        }

            .d-breadcrumb a:hover {
                text-decoration: underline;
            }

    .d-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 1.75rem;
    }

        .d-page-header h1 {
            font-family: 'Syne',sans-serif;
            font-size: 22px;
            font-weight: 600;
            letter-spacing: -.3px;
            margin: 0;
        }

        .d-page-header p {
            font-size: 13px;
            color: #6b7280;
            margin: 3px 0 0;
        }

    .d-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .d-btn {
        padding: 8px 16px;
        border-radius: 8px;
        font-family: 'DM Sans',sans-serif;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: all .15s;
        border: 0.5px solid transparent;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        white-space: nowrap;
    }

        .d-btn svg {
            width: 13px;
            height: 13px;
            flex-shrink: 0;
        }

    .d-btn-primary {
        background: #1a56db;
        border-color: #1a56db;
        color: #fff;
    }

        .d-btn-primary:hover {
            filter: brightness(1.08);
            color: #fff;
        }

    .d-btn-ghost {
        background: transparent;
        border-color: #d1d5db;
        color: #6b7280;
    }

        .d-btn-ghost:hover {
            background: #f3f4f6;
            color: #111827;
        }

    .d-layout {
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 20px;
        align-items: start;
    }

    @@media (max-width:700px) {
        .d-layout {
            grid-template-columns: 1fr;
        }
    }

    /* Profile card */
    .d-profile {
        background: #fff;
        border: 0.5px solid #e5e7eb;
        border-radius: 12px;
        padding: 1.5rem 1.25rem;
        text-align: center;
    }

    .d-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #e8effe;
        border: 2px solid #B5D4F4;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
        font-family: 'Syne',sans-serif;
        font-size: 22px;
        font-weight: 600;
        color: #185FA5;
    }

    .d-profile-name {
        font-family: 'Syne',sans-serif;
        font-size: 15px;
        font-weight: 600;
        margin: 0;
    }

    .d-profile-sub {
        font-size: 12px;
        color: #6b7280;
        margin: 3px 0 0;
    }

    .d-chip {
        display: inline-block;
        margin-top: 8px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
    }

    .d-chip-trainer {
        background: #e8effe;
        color: #185FA5;
        border: 0.5px solid #B5D4F4;
    }

    .d-meta {
        margin-top: 16px;
        border-top: 0.5px solid #e5e7eb;
        padding-top: 14px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        text-align: left;
    }

    .d-meta-row {
        display: flex;
        gap: 8px;
        align-items: flex-start;
    }

    .d-meta-icon {
        width: 28px;
        height: 28px;
        border-radius: 7px;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .d-meta-icon svg {
            width: 13px;
            height: 13px;
            stroke: #6b7280;
        }

    .d-meta-label {
        font-size: 11px;
        color: #9ca3af;
        margin: 0;
    }

    .d-meta-val {
        font-size: 13px;
        font-weight: 500;
        color: #111827;
        margin: 0;
    }

    /* Right column */
    .d-col {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .d-card {
        background: #fff;
        border: 0.5px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
    }

    .d-card-header {
        padding: 12px 20px;
        border-bottom: 0.5px solid #e5e7eb;
        background: #f9fafb;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .d-card-header svg {
            width: 15px;
            height: 15px;
            stroke: #1a56db;
            flex-shrink: 0;
        }

    .d-card-title {
        font-family: 'Syne',sans-serif;
        font-size: 14px;
        font-weight: 500;
        margin: 0;
    }

    .d-card-body {
        padding: 20px;
    }

    /* Info grid */
    .d-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    @@media (max-width:500px) {
        .d-info-grid {
            grid-template-columns: 1fr;
        }
    }

    .d-info-tile {
        background: #f9fafb;
        border: 0.5px solid #e5e7eb;
        border-radius: 8px;
        padding: 12px 14px;
    }

    .d-info-tile-label {
        font-size: 11px;
        font-weight: 500;
        color: #9ca3af;
        letter-spacing: .4px;
        text-transform: uppercase;
        margin: 0 0 5px;
    }

    .d-info-tile-val {
        font-family: 'Syne',sans-serif;
        font-size: 16px;
        font-weight: 600;
        color: #111827;
        margin: 0;
    }

    /* Empty state */
    .d-no-data {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #9ca3af;
        font-size: 13px;
    }

        .d-no-data svg {
            width: 16px;
            height: 16px;
            stroke: #d1d5db;
        }

    /* History table */
    .d-hist {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .d-hist th {
            padding: 9px 14px;
            font-size: 11px;
            font-weight: 500;
            color: #9ca3af;
            letter-spacing: .4px;
            text-transform: uppercase;
            border-bottom: 0.5px solid #e5e7eb;
            text-align: left;
            background: #f9fafb;
        }

        .d-hist td {
            padding: 11px 14px;
            border-bottom: 0.5px solid #f3f4f6;
            color: #374151;
            vertical-align: middle;
        }

        .d-hist tbody tr:last-child td {
            border-bottom: none;
        }

        .d-hist tbody tr:hover td {
            background: #fafafa;
        }
</style>

<div class="d-wrap">

    <div class="d-breadcrumb">
        <a asp-action="Index">Trainers</a>
        <span>›</span>
        <span>@Model.FullName</span>
    </div>

    <div class="d-page-header">
        <div>
            <h1>@Model.FullName</h1>
            <p>Trainer profile — ID #@Model.Id</p>
        </div>
        <div class="d-actions">
            <a asp-action="Index" class="d-btn d-btn-ghost">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M10 3L5 8l5 5" />
                </svg>
                Back
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="d-btn d-btn-primary">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M10 2l4 4-7 7H3v-4l7-7z" />
                </svg>
                Edit trainer
            </a>
        </div>
    </div>

    <div class="d-layout">

        <!-- Profile sidebar -->
        <div class="d-profile">
            <div class="d-avatar">@initials</div>
            <p class="d-profile-name">@Model.FullName</p>
            <p class="d-profile-sub">@Model.PhoneNumber</p>

            <div class="d-chip d-chip-trainer">Trainer</div>

            <div class="d-meta">
                <div class="d-meta-row">
                    <div class="d-meta-icon">
                        <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5"><path d="M3 2h3l1.5 3.5-2 1.5a9 9 0 003.5 3.5l1.5-2L14 12v3a1 1 0 01-1 1A12 12 0 012 3a1 1 0 011-1z" /></svg>
                    </div>
                    <div>
                        <p class="d-meta-label">Phone</p>
                        <p class="d-meta-val">@Model.PhoneNumber</p>
                    </div>
                </div>
                <div class="d-meta-row">
                    <div class="d-meta-icon">
                        <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5"><path d="M8 1l2 3h3l-2.5 2.5L11.5 10 8 8 4.5 10l1-3.5L3 4h3l2-3z" /></svg>
                    </div>
                    <div>
                        <p class="d-meta-label">Specialty</p>
                        <p class="d-meta-val">@Model.Specialty</p>
                    </div>
                </div>
                <div class="d-meta-row">
                    <div class="d-meta-icon">
                        <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5"><path d="M8 1v14M5 4c0-1 1-2 3-2s3 1 3 2-1 2-3 2-3 1-3 2 1 2 3 2 3-1 3-2" /></svg>
                    </div>
                    <div>
                        <p class="d-meta-label">Salary / %</p>
                        <p class="d-meta-val">@Model.SalaryOrPercentage.ToString("N0")</p>
                    </div>
                </div>
                <div class="d-meta-row">
                    <div class="d-meta-icon">
                        <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5"><rect x="2" y="3" width="12" height="11" rx="2" /><path d="M5 1v4M11 1v4M2 8h12" /></svg>
                    </div>
                    <div>
                        <p class="d-meta-label">Joined</p>
                        <p class="d-meta-val">@Model.CreatedAt.ToString("dd MMM yyyy")</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right column -->
        <div class="d-col">

            <!-- Summary tiles -->
            <div class="d-card">
                <div class="d-card-header">
                    <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5">
                        <rect x="1" y="4" width="14" height="9" rx="2" />
                        <path d="M4 4V3a1 1 0 011-1h6a1 1 0 011 1v1M1 8h14" />
                    </svg>
                    <span class="d-card-title">Trainer overview</span>
                </div>
                <div class="d-card-body">
                    <div class="d-info-grid">
                        <div class="d-info-tile">
                            <p class="d-info-tile-label">Specialty</p>
                            <p class="d-info-tile-val">@Model.Specialty</p>
                        </div>
                        <div class="d-info-tile">
                            <p class="d-info-tile-label">Salary / Percentage</p>
                            <p class="d-info-tile-val">@Model.SalaryOrPercentage.ToString("N0")</p>
                        </div>
                        <div class="d-info-tile">
                            <p class="d-info-tile-label">Assigned classes</p>
                            <p class="d-info-tile-val">@Model.AssignedClasses.Count()</p>
                        </div>
                        <div class="d-info-tile">
                            <p class="d-info-tile-label">Joined</p>
                            <p class="d-info-tile-val" style="font-size:14px">@Model.CreatedAt.ToString("dd MMM yyyy")</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Assigned classes -->
            <div class="d-card">
                <div class="d-card-header">
                    <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5">
                        <circle cx="8" cy="8" r="6" />
                        <path d="M8 5v3l2 2" />
                    </svg>
                    <span class="d-card-title">Assigned classes</span>
                </div>
                @if (!Model.AssignedClasses.Any())
                {
                    <div class="d-card-body">
                        <div class="d-no-data">
                            <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5">
                                <path d="M4 8h8M8 4v8" />
                            </svg>
                            No classes assigned to this trainer yet.
                        </div>
                    </div>
                }
                else
                {
                    <div style="overflow-x:auto">
                        <table class="d-hist">
                            <thead>
                                <tr>
                                    <th>Class</th>
                                    <th>Schedule</th>
                                    <th>Duration</th>
                                    <th>Capacity</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.AssignedClasses)
                                {
                                    <tr>
                                        <td style="font-weight:500;color:#111827">@c.Name</td>
                                        <td>@c.ScheduleTime.ToString("dd MMM yyyy HH:mm")</td>
                                        <td>@c.DurationInMinutes min</td>
                                        <td>@c.MaxCapacity</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

        </div>
    </div>
</div>
