@model FitTrack_Pro.ViewModels.TrainerDetailsViewModel

@{
    ViewData["Title"] = "My Trainer Profile";
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar: Personal Info Card -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-lg position-relative overflow-hidden" style="border-radius: 20px; background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); color: white;">
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <div class="d-inline-block p-1 rounded-circle bg-primary bg-gradient shadow-sm">
                            <div class="rounded-circle bg-dark d-flex align-items-center justify-content-center" style="width: 120px; height: 120px; font-size: 3rem; font-weight: bold; color: #3b82f6;">
                                @Model.FullName.Substring(0, 1).ToUpper()
                            </div>
                        </div>
                    </div>
                    <h3 class="fw-bold mb-1">@Model.FullName</h3>
                    <p class="text-info mb-4">@Model.Specialty Trainer</p>
                    
                    <hr class="border-secondary opacity-25">
                    
                    <div class="text-start mt-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-box me-3 bg-secondary bg-opacity-10 rounded-3 p-2">
                                <i class="bi bi-envelope text-primary"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Email Address</small>
                                <span class="fw-medium">@Model.Email</span>
                            </div>
                        </div>
                        
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-box me-3 bg-secondary bg-opacity-10 rounded-3 p-2">
                                <i class="bi bi-telephone text-primary"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Phone Number</small>
                                <span class="fw-medium">@Model.PhoneNumber</span>
                            </div>
                        </div>
                        
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-box me-3 bg-secondary bg-opacity-10 rounded-3 p-2">
                                <i class="bi bi-cash-stack text-primary"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Salary / Percentage</small>
                                <span class="fw-medium text-success">@Model.SalaryOrPercentage.ToString("C")</span>
                            </div>
                        </div>
                        
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-box me-3 bg-secondary bg-opacity-10 rounded-3 p-2">
                                <i class="bi bi-calendar-check text-primary"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Joined On</small>
                                <span class="fw-medium">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="position-absolute bottom-0 start-0 w-100 h-1 bg-primary opacity-50"></div>
            </div>
        </div>

        <!-- Main Content: Schedule/Classes -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h4 class="fw-bold mb-0">My Assigned Classes</h4>
                    <span class="badge bg-primary rounded-pill px-3 py-2">@Model.AssignedClasses.Count() Classes</span>
                </div>
                <div class="card-body p-4">
                    @if (!Model.AssignedClasses.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-calendar-x display-1 text-muted opacity-25"></i>
                            <p class="mt-3 text-muted">You have no assigned classes at the moment.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle custom-table">
                                <thead class="table-light">
                                    <tr>
                                        <th class="border-0 rounded-start">Class Name</th>
                                        <th class="border-0">Schedule Time</th>
                                        <th class="border-0">Duration</th>
                                        <th class="border-0 rounded-end">Capacity</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var gymClass in Model.AssignedClasses)
                                    {
                                        <tr>
                                            <td class="fw-bold text-primary">@gymClass.Name</td>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <span class="fw-semibold text-dark">@gymClass.ScheduleTime.ToString("HH:mm")</span>
                                                    <span class="text-muted small">@gymClass.ScheduleTime.ToString("dddd")</span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border fw-normal">
                                                    <i class="bi bi-clock me-1 text-primary"></i> @gymClass.DurationInMinutes min
                                                </span>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="progress flex-grow-1 me-2" style="height: 6px; width: 60px;">
                                                        <div class="progress-bar bg-primary" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                                                    </div>
                                                    <span class="small text-muted">@gymClass.MaxCapacity</span>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .icon-box {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .custom-table thead th {
        padding: 15px;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }
    
    .custom-table tbody td {
        padding: 20px 15px;
    }
    
    .custom-table tbody tr:last-child td {
        border-bottom: 0;
    }
    
    .custom-table tbody tr {
        transition: all 0.2s ease;
    }
    
    .custom-table tbody tr:hover {
        background-color: #f8fafc !important;
        transform: scale(1.005);
    }
</style>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
